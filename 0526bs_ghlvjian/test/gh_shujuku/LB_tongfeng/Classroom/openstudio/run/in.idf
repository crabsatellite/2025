EnergyManagementSystem:Program,
  classroomdWindowOpening1,               !- Name
  IF (Outdoor_Sensor < 100),              !- Program Line 1
  SET DoorccdOpenFactor1 = 0.0,           !- Program Line 2
  SET AperturecceaOpenFactor2 = 0.0,      !- Program Line 3
  SET ApertureebOpenFactor3 = 0.0,        !- Program Line 4
  SET ApertureaecOpenFactor4 = 0.0,       !- Program Line 5
  SET DooreccebaOpenFactor5 = 0.0,        !- Program Line 6
  SET ApertureabdOpenFactor6 = 0.0,       !- Program Line 7
  ELSE,                                   !- Program Line 8
  SET DoorccdOpenFactor1 = 0,             !- Program Line 9
  SET AperturecceaOpenFactor2 = 0,        !- Program Line 10
  SET ApertureebOpenFactor3 = 0,          !- Program Line 11
  SET ApertureaecOpenFactor4 = 0,         !- Program Line 12
  SET DooreccebaOpenFactor5 = 0,          !- Program Line 13
  SET ApertureabdOpenFactor6 = 0,         !- Program Line 14
  ENDIF;                                  !- Program Line 15

